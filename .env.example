# Copy to .env and fill in your values

ANTHROPIC_API_KEY=sk-ant-...

# Optional: path to a persistent Playwright browser profile
# Keeps you logged into LinkedIn, StepStone etc. between runs
BROWSER_PROFILE_DIR=./data/browser_profile

# Optional: proxy for scraping from outside Germany
# StepStone and some other German boards geoblock non-EU visitors.
# Set this to a German proxy or VPN SOCKS5/HTTP endpoint.
# Examples:
#   PROXY_URL=socks5://user:pass@your-vpn-host:1080
#   PROXY_URL=http://user:pass@proxy.example.com:8080
PROXY_URL=
